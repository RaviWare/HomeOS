# ----------------------------------------------------------------------------
# HomeOS environment (all optional)
# ----------------------------------------------------------------------------
# The built-in Ask Your Data assistant runs fully client-side and needs NO key.
# A key is only required for the optional live web AI chat and document OCR,
# which are powered by Anthropic Claude.
#
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
#
# Optional: override the Claude model (default claude-haiku-4-5).
# A higher-quality option is claude-sonnet-5.
ANTHROPIC_MODEL=
#
# Optional: override the server port (default 3000).
PORT=
