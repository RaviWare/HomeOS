# ----------------------------------------------------------------------------
# HomeOS environment
# ----------------------------------------------------------------------------
# The built-in Ask Your Data assistant runs fully client-side and needs NO key.
# A key is only needed for the optional live AI chat and document OCR (Claude).
#
# PRODUCTION (Cloudflare Workers) - set the key as a secret, never in a file:
# npx wrangler secret put ANTHROPIC_API_KEY
#
# LOCAL DEV:
# - Express dev (npm run dev): put the key in a git-ignored .env file below.
# - Worker dev (npm run cf:dev): put the key in a git-ignored .dev.vars file.
#
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
#
# Optional (defaults shown): model and AI endpoint guards.
ANTHROPIC_MODEL=claude-haiku-4-5
AI_ENABLED=true
AI_DAILY_LIMIT=300
AI_RATE_MAX=20

# Optional: Telegram bot so users can query their vault from chat
# Create a bot via @BotFather, then set:
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_BOT_USERNAME=YourBotName
# TELEGRAM_POLLING=true   # default when token is set (local dev)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=HomeOSBot

# ----------------------------------------------------------------------------
# Clerk Auth + Billing (required for login and paid plans)
# ----------------------------------------------------------------------------
# Pull keys: clerk env pull
# Enable billing: clerk enable billing --for user
# Plans: Dashboard → Billing → Plans (personal / pro / team) or clerk config patch
# Production: connect Stripe in Dashboard → Billing → Settings
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional: for subscription webhooks (server-side lifecycle sync)
# CLERK_WEBHOOK_SIGNING_SECRET=
